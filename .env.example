# =============================================================================
# Environment variables. Copy to `.env` and fill in real values.
#   FastAPI (EC2) uses the [SHARED] + [FASTAPI] sections.
#   Lambda uses the [SHARED] + [LAMBDA] sections (set as Lambda env vars, not a file).
# NEVER commit the real .env. It is in .gitignore.
# =============================================================================

# ----------------------------- [SHARED] -------------------------------------
AWS_REGION=us-east-1
DYNAMODB_REVIEWS_TABLE=reviews
DYNAMODB_REPOSITORIES_TABLE=repositories

# ----------------------------- [FASTAPI] ------------------------------------
# Secret you set when creating the GitHub App webhook. Used to validate
# X-Hub-Signature-256. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# ARN of the SNS topic created by infra/02_create_sns_sqs.sh
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:pr-review-events

# Logging + which PR actions to act on
LOG_LEVEL=INFO
HANDLED_PR_ACTIONS=opened,reopened,synchronize

# ----------------------------- [LAMBDA] -------------------------------------
# GitHub App numeric ID (App settings page).
GITHUB_APP_ID=123456

# The GitHub App private key (.pem you downloaded). When stored as an env var,
# replace real newlines with literal \n. The Lambda config normalizes them back.
# Example: GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# CloudWatch custom metric namespace (must match infra/03 alarms)
METRIC_NAMESPACE=PRReviewer

# Safety limits (optional; defaults shown)
MAX_DIFF_CHARS=60000
MAX_COMMENTS=25
